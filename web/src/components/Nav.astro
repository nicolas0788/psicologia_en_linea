---
import { path } from "../utils/paths";
const menuDesktop = [
  { href: "/", label: "Inicio", classLi: "" },
  { href: "/condicionesPro", label: "CondicionesPro", classLi: "" },
  { href: "/private", label: "Privacidad", classLi: "" },
  { href: "/preguntas-frecuentes", label: "Preguntas", classLi: "" },
  { href: "/form", label: "Comenzar", classLi: "menu-desktop__cta" },
];

const menuMobile = [
  { href: "/", label: "Inicio", classLi: "" },
  { href: "/condicionesPro", label: "Condiciones", classLi: "" },
  { href: "/private", label: "Privacidad", classLi: "" },
  { href: "/preguntas-frecuentes", label: "Preguntas", classLi: "" },
  { href: "/form", label: "Comenzar", classLi: "menu-mobile__cta" },
];

import { Image } from "astro:assets";
import logoImg from "../../src/assets/img/logo2.png";
---

<header class="site-header" id="site-header">
  <nav class="site-nav" aria-label="Navegación principal" id="site-nav">
    <a href="/" class="site-logo">
      <Image
        src={logoImg}
        alt="Logo de Psicología en Línea"
        class="site-logo--img"
      />
    </a>

    <!-- MENU DESKTOP -->
    <ul class="menu-desktop" id="menu-desktop">
      {
        menuDesktop.map((item) => (
          <li class={item.classLi}>
            <a href={path(`${item.href}`)}>{item.label}</a>
          </li>
        ))
      }
    </ul>

    <!-- TOGGLE MOBILE -->
    <button
      id="menu-toggle"
      class="menu-toggle"
      aria-expanded="false"
      aria-controls="menu-mobile"
      aria-label="Abrir menú"
      type="button"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>

  <!-- MENU MOBILE -->
  <div id="menu-mobile" class="menu-mobile" aria-hidden="true">
    <ul>
      {
        menuMobile.map((item) => (
          <li class={item.classLi}>
            <a href={item.href}>{item.label}</a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<!-- OVERLAY -->
<div id="menu-overlay" class="menu-overlay" hidden></div>

<style is:global>
  :root {
    /* ================= COLORES BASE ================= */
    --nav-color-bg: transparent;
    --nav-color-text: #ffffff;
    --nav-color-text-hover: #1f4e79;
    --nav-color-overlay: #1f4e79;
    --nav-color-layer: #1f4e79;
    --nav-color-cta-bg-hover: #759deb;
    --nav-color-cta-text-hover: #0d0e0e;
    --nav-color-mobile-border: rgba(255, 255, 255, 0.22);

    /* ================= ALTURAS ================= */
    --nav-height-desktop: 6.5rem;
    --nav-height-mobile: 5rem;

    /* ================= ANCHOS Y ESPACIADOS ================= */
    --nav-width: 100%;
    --nav-padding-inline-mobile: 1rem;
    --nav-padding-inline-desktop: 2rem;
    --nav-gap-desktop: 2rem;
    --nav-gap-mobile: 0;
    --nav-mobile-list-padding-y: 1rem;
    --nav-mobile-list-padding-x: clamp(1rem, 20vw, 12.8rem);
    --nav-mobile-item-padding: 1rem;
    --nav-mobile-link-padding-y: 1rem;
    --nav-mobile-link-padding-x: 0;

    /* ================= LOGO ================= */
    --nav-logo-height: 80%;
    --nav-logo-width: auto;

    /* ================= LINKS ================= */
    --nav-link-font-size: 1rem;
    --nav-link-font-weight: 500;
    --nav-link-line-height: 1.2;
    --nav-link-text-decoration: none;

    /* ================= UNDERLINE DESKTOP ================= */
    --nav-underline-height: 1.5px;
    --nav-underline-offset: -0.25rem;
    --nav-underline-duration: 0.7s;
    --nav-underline-ease: ease;
    --nav-underline-origin: center;

    /* ================= CTA ================= */
    --nav-cta-border-width: 2px;
    --nav-cta-padding-y: 0.5rem;
    --nav-cta-padding-x: 1rem;
    --nav-cta-radius: 6px;
    --nav-cta-transition-duration-txt: 1s;
    --nav-cta-transition-duration-bg: 1.5s;

    /* ================= TOGGLE ================= */
    --nav-toggle-size: 28px;
    --nav-toggle-line-width: 28px;
    --nav-toggle-line-height: 4px;
    --nav-toggle-gap: 5px;
    --nav-toggle-line-radius: 999px;
    --nav-toggle-translate-y: 9px;

    /* ================= CAPAS Y ANIMACIONES ================= */
    --nav-layer-duration: 0.8s;
    --nav-layer-ease: ease;
    --nav-mobile-duration: 0.8s;
    --nav-mobile-ease: ease;
    --nav-mobile-item-duration-opacity: 0.3s;
    --nav-mobile-item-duration-transform: 0.55s;
    --nav-mobile-item-offset-y: 42px;

    /* ================= BORDES ================= */
    --nav-mobile-item-border-width: 1px;

    /* ================= Z-INDEX ================= */
    --nav-z-nav: 1000;
    --nav-z-content: 1010;
    --nav-z-overlay: 900;
    --nav-z-mobile: 910;

    /* ================= BREAKPOINT ================= */
    --nav-breakpoint-desktop: 1024px;
  }

  /* ================= HEADER ================= */

  .site-header {
    position: relative;
  }

  /* ================= NAV ================= */

  .site-nav {
    position: fixed;
    inset: 0 auto auto 0;
    width: var(--nav-width);
    height: var(--nav-height-mobile);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-inline: var(--nav-padding-inline-mobile);
    background-color: var(--nav-color-bg);
    overflow: hidden;
    z-index: var(--nav-z-nav);
  }

  /* ================= LAYER ================= */

  .site-nav::before {
    content: "";
    position: absolute;
    inset: 0;
    width: 100%;
    height: var(--nav-height-mobile);
    background: var(--nav-color-layer);
    transform: translateY(-100%);
    opacity: 0;
    z-index: 0;
    pointer-events: none;
    transition:
      transform var(--nav-layer-duration) var(--nav-layer-ease),
      opacity var(--nav-layer-duration) var(--nav-layer-ease);
  }

  .site-nav.is-scrolled::before {
    transform: translateY(0);
    opacity: 1;
  }

  /* ================= LOGO ================= */

  .site-logo {
    position: relative;
    display: inline-flex;
    align-items: center;
    height: var(--nav-logo-height);
    width: var(--nav-logo-width);
    z-index: var(--nav-z-content);
  }

  .site-logo--img {
    display: block;
    height: 100%;
    width: auto;
  }

  /* ================= DESKTOP MENU ================= */

  .menu-desktop {
    display: none;
    align-items: center;
    justify-content: space-between;
    gap: var(--nav-gap-desktop);
    position: relative;
    z-index: var(--nav-z-content);
  }

  .menu-desktop li {
    list-style: none;
  }

  .menu-desktop a {
    position: relative;
    display: inline-flex;
    align-items: center;
    font-size: var(--nav-link-font-size);
    font-weight: var(--nav-link-font-weight);
    line-height: var(--nav-link-line-height);
    text-decoration: var(--nav-link-text-decoration);
    color: var(--nav-color-text);
    transition:
      color var(--nav-cta-transition-duration-txt) ease,
      background-color var(--nav-cta-transition-duration-txt) ease,
      border-color var(--nav-cta-transition-duration-txt) ease;
  }

  /* ================= DESKTOP UNDERLINE ================= */

  .menu-desktop li:not(.menu-desktop__cta) a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: var(--nav-underline-offset);
    width: 100%;
    height: var(--nav-underline-height);
    background-color: currentColor;
    transform: scaleX(0);
    transform-origin: var(--nav-underline-origin);
    transition: transform var(--nav-underline-duration)
      var(--nav-underline-ease);
    pointer-events: none;
  }

  .menu-desktop li:not(.menu-desktop__cta) a:hover::after,
  .menu-desktop li:not(.menu-desktop__cta) a:focus-visible::after {
    transform: scaleX(1);
  }

  /* ================= DESKTOP CTA ================= */

  .menu-desktop .menu-desktop__cta a {
    border: var(--nav-cta-border-width) solid var(--nav-color-text);
    padding: var(--nav-cta-padding-y) var(--nav-cta-padding-x);
    border-radius: var(--nav-cta-radius);
  }

  .menu-desktop .menu-desktop__cta a:hover,
  .menu-desktop .menu-desktop__cta a:focus-visible {
    background-color: var(--nav-color-cta-bg-hover);
    color: var(--nav-color-cta-text-hover);
  }

  /* ================= TOGGLE ================= */

  .menu-toggle {
    position: relative;
    width: var(--nav-toggle-size);
    height: var(--nav-toggle-size);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--nav-toggle-gap);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    z-index: var(--nav-z-content);
  }

  .menu-toggle span {
    display: block;
    width: var(--nav-toggle-line-width);
    height: var(--nav-toggle-line-height);
    border-radius: var(--nav-toggle-line-radius);
    background: var(--nav-color-text);
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
  }

  .site-header.is-open .menu-toggle span:nth-child(1) {
    transform: translateY(var(--nav-toggle-translate-y)) rotate(45deg);
  }

  .site-header.is-open .menu-toggle span:nth-child(2) {
    opacity: 0;
  }

  .site-header.is-open .menu-toggle span:nth-child(3) {
    transform: translateY(calc(var(--nav-toggle-translate-y) * -1))
      rotate(-45deg);
  }

  /* ================= MOBILE MENU ================= */

  .menu-mobile {
    position: fixed;
    inset: var(--nav-height-mobile) 0 0 0;
    width: 100%;
    text-align: center;
    transform: translateX(-100%);
    opacity: 0;
    z-index: var(--nav-z-mobile);
    transition:
      transform var(--nav-mobile-duration) var(--nav-mobile-ease),
      opacity var(--nav-mobile-duration) var(--nav-mobile-ease);
  }

  .site-header.is-open .menu-mobile {
    transform: translateX(0);
    opacity: 1;
  }

  .menu-mobile ul {
    margin: 0;
    padding: var(--nav-mobile-list-padding-y) var(--nav-mobile-list-padding-x);
  }

  .menu-mobile li {
    list-style: none;
    padding: var(--nav-mobile-item-padding);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    border-bottom: var(--nav-mobile-item-border-width) solid
      var(--nav-color-mobile-border);
    transform: translateY(var(--nav-mobile-item-offset-y));
    transition:
      opacity var(--nav-mobile-item-duration-opacity) ease,
      transform var(--nav-mobile-item-duration-transform) ease;
  }

  .site-header.is-open .menu-mobile li {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  .site-header.is-open .menu-mobile li:nth-child(1) {
    transition-delay: 0.1s;
  }
  .site-header.is-open .menu-mobile li:nth-child(2) {
    transition-delay: 0.25s;
  }
  .site-header.is-open .menu-mobile li:nth-child(3) {
    transition-delay: 0.4s;
  }
  .site-header.is-open .menu-mobile li:nth-child(4) {
    transition-delay: 0.55s;
  }
  .site-header.is-open .menu-mobile li:nth-child(5) {
    transition-delay: 0.7s;
  }

  .menu-mobile a {
    display: block;
    padding: var(--nav-mobile-link-padding-y) var(--nav-mobile-link-padding-x);
    font-size: var(--nav-link-font-size);
    font-weight: var(--nav-link-font-weight);
    line-height: var(--nav-link-line-height);
    text-decoration: none;
    color: var(--nav-color-text);
  }

  .menu-mobile .menu-mobile__cta a {
    border: var(--nav-cta-border-width) solid var(--nav-color-text);
    border-radius: var(--nav-cta-radius);
  }

  .menu-mobile .menu-mobile__cta a:hover,
  .menu-mobile .menu-mobile__cta a:focus-visible {
    background-color: var(--nav-color-cta-bg-hover);
    color: var(--nav-color-cta-text-hover);
  }

  /* ================= OVERLAY ================= */

  .menu-overlay {
    position: fixed;
    inset: 0;
    background-color: var(--nav-color-overlay);
    pointer-events: none;
    opacity: 0;
    transform: translateX(-100%);
    z-index: var(--nav-z-overlay);
    transition:
      transform var(--nav-layer-duration) var(--nav-layer-ease),
      opacity var(--nav-layer-duration) var(--nav-layer-ease);
  }

  .menu-overlay.is-active {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(0);
  }

  /* ================= DESKTOP ================= */

  @media (min-width: 1024px) {
    .site-nav {
      height: var(--nav-height-desktop);
      padding-inline: var(--nav-padding-inline-desktop);
    }

    .site-nav::before {
      height: var(--nav-height-desktop);
    }

    .menu-toggle {
      display: none;
    }

    .menu-desktop {
      display: flex;
    }

    .menu-mobile,
    .menu-overlay {
      display: none;
    }
  }
</style>
