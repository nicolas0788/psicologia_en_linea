---
const menuItems = [
  { label: "Inicio", href: "/" },
  { label: "Profesionales", href: "#" },
  { label: "Cómo trabajamos", href: "#" },
  { label: "Quiénes somos", href: " #" },
  { label: "Preguntas frecuentes", href: "#" },
  { label: "Privacidad y condiciones", href: "#" },
];
---

<header class="site-header" id="site-header">
  <nav class="site-nav" aria-label="Navegación principal" id="site-nav">
    <a href="/" class="site-logo"
      ><img
        src="../../src/assets/img/logo2.png"
        alt="Logo Psicología en Línea"
        class="site-logo--img"
      /></a
    >

    <!-- MENU DESKTOP -->
    <ul class="menu-desktop" id="menu-desktop">
      <li><a href="#inicio">Inicio</a></li>
      <li><a href="#servicios">Servicios</a></li>
      <li><a href="#sobre">Sobre mí</a></li>
      <li><a href="#contacto">Contacto</a></li>
    </ul>

    <!-- TOGGLE MOBILE -->
    <button
      id="menu-toggle"
      class="menu-toggle"
      aria-expanded="false"
      aria-controls="menu-mobile"
      aria-label="Abrir menú"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>

  <!-- MENU MOBILE -->
  <div id="menu-mobile" class="menu-mobile" aria-hidden="true">
    <ul>
      <li><a href="#inicio">Inicio</a></li>
      <li><a href="#servicios">Servicios</a></li>
      <li><a href="#sobre">Sobre mí</a></li>
      <li><a href="#contacto">Contacto</a></li>
    </ul>
  </div>
</header>

<!-- OVERLAY -->
<div id="menu-overlay" class="menu-overlay" hidden></div>

<style is:global>
  :root {
    --color-bg: transparent;
    --color-text: #fff;
    --color-overlay: #1f4e79;
    --color-layer: #1f4e79;

    --height-desktop: 6.5rem;
    --height-mobile: 5rem;
  }

  /* ================= HEADER ================= */

  .site-header {
    position: relative; /* referencia para menu mobile */
  }

  /* ================= NAV ================= */

  .site-nav {
    position: fixed;
    width: 100%;
    height: var(--height-mobile);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
    background-color: var(--color-bg);
    overflow: hidden;
  }

  /* ================= LAYER ================= */

  .site-nav::before {
    content: "";
    position: absolute;
    width: 100%;
    height: var(--height-mobile);
    inset: 0;
    background: var(--color-layer);
    transform: translateY(-100%);
    opacity: 0;
    z-index: 0;
    pointer-events: none;
    transition:
      transform 0.8s ease,
      opacity 0.8s ease;
  }

  .site-nav.is-scrolled::before {
    transform: translateY(0);
    opacity: 1;
  }

  /* ================= LOGO ================= */

  .site-logo {
    position: relative;
    height: 100%;
    width: auto;
  }

  .site-logo--img {
    height: 100%;
    width: auto;
  }

  /* ================= DESKTOP ================= */

  .menu-desktop {
    display: none;
    gap: 2rem;
    position: relative;
  }

  .menu-desktop a {
    color: var(--color-text);
  }

  /* ================= TOGGLE ================= */

  .menu-toggle {
    position: relative;
    width: 28px;
    height: 28px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
  }

  .menu-toggle span {
    width: 28px;
    height: 4px;
    background: var(--color-text);
    transition: transform 0.3s;
  }

  /* CRUZ */
  .site-header.is-open .menu-toggle span:nth-child(1) {
    transform: translateY(9px) rotate(45deg);
  }
  .site-header.is-open .menu-toggle span:nth-child(2) {
    opacity: 0;
  }
  .site-header.is-open .menu-toggle span:nth-child(3) {
    transform: translateY(-9px) rotate(-45deg);
  }

  /* ================= MOBILE MENU ================= */

  .menu-mobile {
    position: fixed;
    inset: var(--height-mobile) 0 0 0;
    width: 100%;
    text-align: center;

    /* ESTADO CERRADO */
    transform: translateX(-100%);
    opacity: 0;
  }

  /* ABIERTO */
  .site-header.is-open .menu-mobile {
    transform: translateX(0);
    opacity: 1;
  }

  /* LINKS */
  .menu-mobile ul {
    padding: 1rem clamp(1rem, 20vw, 12.8rem);
  }

  /* ESTADO CERRADO */
  .menu-mobile li {
    padding: 1rem;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    border-bottom: 1px solid black;
    transform: translateY(42px);
    transition:
      opacity 0.3s ease,
      transform 0.55s ease;
  }

  /* ABIERTO */
  .site-header.is-open .menu-mobile li {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  .site-header.is-open .menu-mobile li:nth-child(1) {
    transition-delay: 0.1s;
  }

  .site-header.is-open .menu-mobile li:nth-child(2) {
    transition-delay: 0.25s;
  }

  .site-header.is-open .menu-mobile li:nth-child(3) {
    transition-delay: 0.4s;
  }

  .site-header.is-open .menu-mobile li:nth-child(4) {
    transition-delay: 0.55s;
  }

  .menu-mobile a {
    display: block;
    padding: 1rem 0;
    color: var(--color-text);
  }

  /* ================= OVERLAY ================= */

  .menu-overlay {
    position: fixed;
    top: 0;
    right: 0;
    left: 0;
    bottom: 0;

    background-color: var(--color-overlay);
    pointer-events: none;
    opacity: 0;
    transform: translateX(-100%);
    transition:
      transform 0.8s ease,
      opacity 0.8s ease;
  }

  .menu-overlay.is-active {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(0);
  }

  /* ================= Z-INDEX ================= */
  .site-nav {
    z-index: 1000;
  }
  .site-logo,
  .menu-toggle,
  .menu-desktop {
    z-index: 1010;
  }
  .menu-overlay {
    z-index: 900;
  }

  .menu-mobile {
    z-index: 910;
  }

  /* ================= DESKTOP BREAKPOINT ================= */

  @media (min-width: 1024px) {
    .menu-toggle {
      display: none;
    }

    .menu-desktop {
      display: flex;
    }

    .menu-mobile {
      display: none;
    }

    .menu-overlay {
      display: none;
    }

    .site-nav {
      height: var(--height-desktop);
    }

    .site-nav::before {
      height: var(--height-desktop);
    }
  }
</style>
