---
import ArcoSuperior from "./assets/ArcoSuperior.astro";
import Btn from "./assets/Btn.astro";
import { Image } from "astro:assets";
import heroImg from "../../assets/img/hero/heroImg3.png";
---

<section class="section-hero">
  <ArcoSuperior />
  <div class="container-general hero-container">
    <div class="hero-texts">
      <h1 class="title-general">¿No sabés por dónde empezar?</h1>
      <h2 class="subtitle-general">
        Encontrar psicólogo/a puede sentirse difícil
      </h2>
      <h2 class="subtitle-general">Lo hicimos <span>más simple</span></h2>
      <div class="hero-info__container"></div>
      <div class="btn-container">
        <Btn href="/form" label="Comenzar ahora" />
      </div>
    </div>

    <div class="hero-img__container">
      <Image src={heroImg} alt="Descripción de la imagen" />
    </div>
  </div>
</section>

<style is:global>
  .section-hero {
    width: 100%;
    height: 100%;
    min-height: 100vh;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background: linear-gradient(180deg, #8d9cdb 0%, #f8fbfd 100%);
    overflow: hidden;
  }

  .hero-container {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding-top: min(5rem, 20vh);
  }

  .hero-texts {
    display: flex;
    flex-direction: column;
    justify-content: start;
    align-items: center;
    gap: 2rem;
    order: 1;
  }

  /* ================= ANIMACIÓN HERO TEXT ================= */

  .hero-texts > * {
    opacity: 0;
    transform: translateY(20px);
    animation: heroFadeUp 1.8s ease forwards;
    will-change: opacity, transform;
  }

  .hero-texts .title-general {
    animation-delay: 0.2s;
  }

  .hero-texts .subtitle-general:nth-of-type(1) {
    animation-delay: 0.5s;
  }

  .hero-texts .subtitle-general:nth-of-type(2) {
    animation-delay: 0.8s;
  }

  .hero-texts .btn-container {
    animation-delay: 1.15s;
  }

  .subtitle-general span {
    display: inline-block;
    font-weight: 900;
    opacity: 0;
    transform: scale(0.9);
    animation: heroPopIn 0.45s ease forwards;
    animation-delay: 1.05s;
    will-change: opacity, transform;
  }

  @keyframes heroFadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes heroPopIn {
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* ================= IMAGEN ================= */

  .hero-img__container {
    position: relative;
    width: min(90%, 500px);
    height: auto;
    order: 0;

    opacity: 0;
    transform: translateY(-80px);
    animation: heroImageDrop 1.8s ease-out forwards;
    animation-delay: 0.2s;
    will-change: opacity, transform;
  }

  .hero-img {
    height: auto;
    width: 100%;
  }

  @keyframes heroImageDrop {
    0% {
      opacity: 0;
      transform: translateY(-80px);
    }

    60% {
      opacity: 1;
      transform: translateY(10px);
    }

    80% {
      transform: translateY(-4px);
    }

    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ================= TEXTOS ================= */

  .title-general {
    font-size: clamp(1rem, 6vw, 2.5rem);
    line-height: 1.5;
    white-space: nowrap;
  }

  .subtitle-general {
    font-size: clamp(0.8rem, 4vw, 1.5rem);
    line-height: 1.4;
    white-space: nowrap;
  }

  /* ================= BOTÓN ================= */

  .btn-container {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* ================= ACCESIBILIDAD ================= */

  @media (prefers-reduced-motion: reduce) {
    .hero-texts > *,
    .subtitle-general span,
    .hero-img__container {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }

  /* ================= DESKTOP ================= */

  @media (min-width: 1024px) {
    .section-hero {
      min-height: 800px;
    }

    .hero-container {
      position: relative;
      display: flex;
      flex-direction: row;
      justify-content: center;
      align-items: start;
      padding-top: 2rem;
    }

    .hero-texts {
      order: 0;
    }

    .hero-img__container {
      order: 1;
    }
  }
</style>
