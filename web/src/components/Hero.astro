---
import ArcoSuperior from "./assets/ArcoSuperior.astro";
import Btn from "./assets/Btn.astro";
---

<section class="section-hero">
  <ArcoSuperior />
  <div class="container-general hero-container">
    <h1 class="subtitle-general">Plataforma de derivación</h1>
    <h2 class="subtitle-general">Creada por psicólogos y psicólogas</h2>
    <div class="hero-info__container">
      <p>Atencion presencial en CABA</p>
      <p>Modalidad online en todo el mundo</p>
    </div>
    <div class="hero-img__container">
      <img
        src="../../src/assets/img/hero/heroImg2.png"
        alt="sdsd"
        class="hero-img"
      />

      <div class="steam" aria-hidden="true">
        <span class="steam-line steam-1"></span>
        <span class="steam-line steam-2"></span>
        <span class="steam-line steam-3"></span>
        <span class="steam-line steam-4"></span>
        <span class="steam-line steam-5"></span>
      </div>
    </div>
  </div>
  <div class="btn-container">
    <Btn href="/form" label="Comenzar ahora" />
  </div>
</section>

<style is:global>
  .section-hero {
    width: 100%;
    height: 100vh;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background: linear-gradient(180deg, #8d9cdb 0%, #f8fbfd 100%);
    overflow: hidden;
  }
  .hero-container {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }
  .hero-container h1,
  .hero-container h2 {
    text-align: center;
  }

  .hero-info__container {
    top: calc(10rem + var(--height-desktop));
    left: 0;
    position: absolute;
    display: flex;
    flex-direction: column;
    justify-content: start;
    align-items: start;
    gap: 2rem;
    width: 20rem;
    z-index: 1;
    display: none;
  }
  .h1 {
    font-size: 1rem;
  }
  .hero-info__container p {
    font-size: 1.5rem;
    font-weight: bold;
  }

  .hero-img__container {
    position: relative;
    width: min(90%, 500px);
    height: auto;
  }

  .hero-img {
    height: auto;
    width: 100%;
  }
  .btn-container {
    position: absolute;
    bottom: 10%;
    left: 50%;
    transform: translateX(-50%);
  }

  /* =========================
   HUMO
========================= */

  .steam {
    position: absolute;
    left: 50%;
    bottom: 52%;
    transform: translateX(-50%);
    width: 120px;
    height: 180px;
    z-index: 3;
    pointer-events: none;

    /* temporal para debug */
    /* background: rgba(255, 0, 0, 0.08); */
  }

  .steam-line {
    position: absolute;
    bottom: 0;
    width: 26px;
    height: 110px;
    background: rgba(199, 197, 197, 0.65);
    border-radius: 999px;
    filter: blur(12px);
    opacity: 0;
    animation: steamFloat 3.6s ease-in-out infinite;
  }

  .steam-1 {
    left: 10px;
    animation-delay: 0s;
  }

  .steam-2 {
    left: 45px;
    animation-delay: 1s;
  }

  .steam-3 {
    left: 80px;
    animation-delay: 2s;
  }

  @keyframes steamFloat {
    0% {
      opacity: 0;
      transform: translateY(0) translateX(0) scale(0.9);
    }

    20% {
      opacity: 0.6;
    }

    50% {
      opacity: 0.45;
      transform: translateY(-40px) translateX(10px) scale(1.1);
    }

    100% {
      opacity: 0;
      transform: translateY(-95px) translateX(-8px) scale(1.35);
    }
  }
</style>
