---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

import instagramIcon from "../assets/img/icons/insta.svg";
import wspIcon from "../assets/img/icons/wsp.svg";
import faceIcon from "../assets/img/icons/face.svg";
import mailIcon from "../assets/img/icons/mail.svg";
import mapsIcon from "../assets/img/icons/maps.svg";

interface FooterLinkImage {
  src: ImageMetadata;
  alt: string;
  width?: number;
  height?: number;
}

interface FooterLink {
  label?: string;

  href: string;

  img?: FooterLinkImage;

  target?: "_blank" | "_self";

  rel?: string;
}

interface FooterColumn {
  title: string;
  links: FooterLink[];
}

interface FooterBrand {
  title: string;
  description?: string;
}

interface FooterProps {
  brand?: FooterBrand;
  columns?: FooterColumn[];
  copyright?: string;
  madeWith?: string;
}

const {
  brand = {
    title: "",
    description: "",
  },

  columns = [
    {
      title: "PLATAFORMA",
      links: [
        { label: "Inicio", href: "/" },
        { label: "¿Cómo funciona?", href: "/#como-funciona" },
        { label: "Contacto", href: "/contacto" },
        { label: "Preguntas frecuentes", href: "/preguntas-frecuentes" },
      ],
    },

    {
      title: "REDES",
      links: [
        {
          img: {
            src: instagramIcon,
            alt: "Icono de Instagram",
            width: 18,
            height: 18,
          },
          label: "psicologiaenlinea.ar",
          href: "https://instagram.com/psicologiaenlinea.ar",
          target: "_blank",
          rel: "noopener noreferrer",
        },
        {
          img: {
            src: faceIcon,
            alt: "Icono de Facebook",
            width: 18,
            height: 18,
          },
          label: "psicologiaenlinea.ar",
          href: "https://facebook.com/psicologiaenlinea.ar",
          target: "_blank",
          rel: "noopener noreferrer",
        },
        {
          img: {
            src: wspIcon,
            alt: "Icono de WhatsApp",
            width: 18,
            height: 18,
          },
          label: "+54 9 11 4947-4689",
          href: "https://wa.me/5491149474689",
          target: "_blank",
          rel: "noopener noreferrer",
        },
        {
          img: {
            src: mailIcon,
            alt: "Icono de mail",
            width: 18,
            height: 18,
          },
          label: "contacto@psicologiaenlinea.ar",
          href: "mailto:contacto@psicologiaenlinea.ar",
        },
      ],
    },

    {
      title: "LEGALES",
      links: [
        { label: "Condiciones profesionales", href: "/condicionesPro" },
        { label: "Condiciones consultantes", href: "/private" },
      ],
    },
  ],

  copyright = "© 2026 Psicología en Línea",

  madeWith = "Buenos Aires, Argentina",
} = Astro.props as FooterProps;

const hasBrand = Boolean(brand?.title?.trim() || brand?.description?.trim());
---

<footer class="site-footer">
  <div class="site-footer__container">
    <div class="site-footer__top">
      {
        hasBrand && (
          <div class="site-footer__brand">
            {brand.title && (
              <h2 class="site-footer__brand-title">{brand.title}</h2>
            )}

            {brand.description && (
              <p class="site-footer__brand-description">{brand.description}</p>
            )}
          </div>
        )
      }

      <nav class="site-footer__nav" aria-label="Footer">
        {
          columns.map((column) => (
            <div class="site-footer__column">
              <h3 class="site-footer__column-title">{column.title}</h3>

              <ul class="site-footer__list">
                {column.links.map((link) => {
                  const image = link.img;

                  const hasLabel = Boolean(link.label?.trim());

                  const hasImage = Boolean(image?.src);

                  /*
                      ============================================================
                      Si no tiene imagen ni label, no renderizamos el item
                      ============================================================
                    */

                  if (!hasLabel && !hasImage) {
                    return null;
                  }

                  return (
                    <li class="site-footer__item">
                      <a
                        class="site-footer__link"
                        href={link.href}
                        target={link.target}
                        rel={link.rel}
                      >
                        {hasImage && image && (
                          <Image
                            class="site-footer__link-img"
                            src={image.src}
                            alt={image.alt}
                            width={image.width}
                            height={image.height}
                          />
                        )}

                        {hasLabel && (
                          <span class="site-footer__link-label">
                            {link.label}
                          </span>
                        )}
                      </a>
                    </li>
                  );
                })}
              </ul>
            </div>
          ))
        }
      </nav>
    </div>

    <div class="site-footer__bottom">
      {copyright && <p>{copyright}</p>}

      {
        madeWith && (
          <div class="site-footer__made-with">
            <Image
              class="site-footer__made-with-icon"
              src={mapsIcon}
              alt="Hecho con amor"
              width={16}
              height={16}
            />

            <p>{madeWith}</p>
          </div>
        )
      }
    </div>
  </div>
</footer>

<style>
  .site-footer {
    --footer-bg: #393092;
    --footer-text: var(--color-text-light);
    --footer-muted: rgba(255, 255, 255, 0.62);
    --footer-line: rgba(255, 255, 255, 0.12);
    --footer-link-hover: #ffffff;

    background: var(--footer-bg);

    color: var(--footer-text);

    padding: 3rem 1.25rem 1.5rem;
  }

  .site-footer__container {
    width: min(100%, 1260px);

    margin: 0 auto;
  }

  .site-footer__top {
    display: flex;

    flex-direction: column;

    gap: 2.5rem;
  }

  .site-footer__brand {
    max-width: 360px;
  }

  .site-footer__brand-title {
    margin: 0 0 1rem;

    font-size: 1.6rem;

    font-weight: 700;
  }

  .site-footer__brand-description {
    margin: 0;

    color: var(--footer-muted);

    font-size: 1.05rem;

    line-height: 1.65;
  }

  .site-footer__nav {
    display: flex;

    flex-direction: column;
    margin: auto;

    gap: 2rem;
  }

  .site-footer__column-title {
    margin: 0 0 1rem;

    font-size: 0.95rem;

    font-weight: 700;

    letter-spacing: 0.06em;

    color: var(--footer-text);
  }

  .site-footer__list {
    display: flex;

    flex-direction: column;

    gap: 0.75rem;

    margin: 0;

    padding: 0;

    list-style: none;
  }

  .site-footer__item {
    margin: 0;
  }

  .site-footer__link {
    display: inline-flex;

    align-items: center;

    gap: 0.6rem;

    color: var(--footer-muted);

    font-size: 1rem;

    text-decoration: none;

    transition:
      color 0.2s ease,
      opacity 0.2s ease;
  }

  .site-footer__link:hover {
    color: var(--footer-link-hover);
  }

  .site-footer__link-img {
    width: 1.1rem;

    height: 1.1rem;

    object-fit: contain;

    flex: 0 0 auto;
  }

  .site-footer__link img {
    height: 22px;
    width: auto;
    filter: brightness(0) invert(1);
  }
  .site-footer__link-label {
    line-height: 1.2;
    color: var(--footer-text);
    opacity: 0.8;
  }

  .site-footer__bottom {
    display: flex;

    flex-direction: column;
    align-items: center;

    gap: 1rem;

    margin-top: 3rem;

    padding-top: 1.5rem;

    border-top: 1px solid var(--footer-line);

    color: var(--footer-muted);

    font-size: 0.95rem;
  }

  .site-footer__bottom p {
    margin: 0;
    color: var(--footer-text);
    opacity: 0.8;
  }

  .site-footer__made-with {
    display: inline-flex;

    align-items: center;

    gap: 0.5rem;
  }
  .site-footer__made-with img {
    filter: brightness(0) invert(1);
  }

  .site-footer__made-with-icon {
    width: 16px;

    height: 16px;

    object-fit: contain;

    flex: 0 0 auto;
  }

  @media (min-width: 768px) {
    .site-footer__nav {
      flex-direction: row;

      justify-content: space-between;

      gap: 3rem;
    }

    .site-footer__bottom {
      flex-direction: row;

      justify-content: space-between;

      align-items: center;
    }
  }

  @media (min-width: 1024px) {
    .site-footer {
      padding: 4rem 2rem 1.75rem;
    }

    .site-footer__top {
      flex-direction: row;

      justify-content: center;

      align-items: flex-start;
    }

    .site-footer__nav {
      width: 60%;
    }
  }
</style>
