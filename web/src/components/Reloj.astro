<div class="pendulum-clock">
  <div class="pendulum-clock__top"></div>

  <div class="pendulum-clock__face">
    <span class="mark mark--12"></span>
    <span class="mark mark--3"></span>
    <span class="mark mark--6"></span>
    <span class="mark mark--9"></span>

    <div class="hand hand--hour"></div>
    <div class="hand hand--minute"></div>
    <div class="clock-center"></div>
  </div>

  <div class="pendulum-clock__body">
    <div class="pendulum-window">
      <div class="pendulum">
        <div class="pendulum__rod"></div>
        <div class="pendulum__bob"></div>
      </div>
    </div>
  </div>

  <div class="pendulum-clock__base"></div>
</div>

<style>
  .pendulum-clock {
    --wood-dark: #4e311f;
    --wood-mid: #6f472b;
    --wood-light: #8a5b38;
    --gold-1: #d7b267;
    --gold-2: #b8872e;
    --face: #f3ecdf;
    --line: #2e2219;
    --glass: rgba(255, 255, 255, 0.1);

    width: 220px;
    display: flex;
    flex-direction: column;
    align-items: center;
    filter: drop-shadow(0 14px 22px rgba(0, 0, 0, 0.18));
  }

  /* remate superior */
  .pendulum-clock__top {
    width: 180px;
    height: 28px;
    border-radius: 18px 18px 10px 10px;
    background: linear-gradient(to bottom, #7f5230, #5b3923);
    box-shadow:
      inset 0 2px 3px rgba(255, 255, 255, 0.12),
      inset 0 -3px 4px rgba(0, 0, 0, 0.18);
  }

  /* caja principal */
  .pendulum-clock__body {
    width: 200px;
    min-height: 340px;
    margin-top: -6px;
    padding: 18px 16px 20px;
    border-radius: 28px 28px 18px 18px;
    background: linear-gradient(
      to right,
      var(--wood-dark) 0%,
      var(--wood-light) 18%,
      var(--wood-mid) 50%,
      var(--wood-light) 82%,
      var(--wood-dark) 100%
    );
    box-shadow:
      inset 0 0 0 2px rgba(255, 255, 255, 0.05),
      inset 0 10px 14px rgba(255, 255, 255, 0.06),
      inset 0 -12px 18px rgba(0, 0, 0, 0.18);
    position: relative;
  }

  /* reloj */
  .pendulum-clock__face {
    width: 118px;
    height: 118px;
    margin: 0 auto 24px;
    border-radius: 50%;
    position: relative;
    background: radial-gradient(
      circle at 35% 30%,
      #fffdf8,
      var(--face) 65%,
      #ddd1bd 100%
    );
    border: 8px solid #c69a46;
    box-shadow:
      inset 0 0 0 2px rgba(70, 40, 15, 0.28),
      0 3px 8px rgba(0, 0, 0, 0.2);
  }

  /* marcas */
  .mark {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 4px;
    height: 14px;
    background: var(--line);
    border-radius: 2px;
    transform-origin: center -42px;
  }

  .mark--12 {
    transform: translate(-50%, -50%) rotate(0deg);
  }
  .mark--3 {
    transform: translate(-50%, -50%) rotate(90deg);
  }
  .mark--6 {
    transform: translate(-50%, -50%) rotate(180deg);
  }
  .mark--9 {
    transform: translate(-50%, -50%) rotate(270deg);
  }

  /* agujas */
  .hand {
    position: absolute;
    left: 50%;
    bottom: 50%;
    transform-origin: center bottom;
    border-radius: 999px;
  }

  .hand--hour {
    width: 6px;
    height: 28px;
    background: #3a2a1d;
    transform: translateX(-50%) rotate(35deg);
  }

  .hand--minute {
    width: 4px;
    height: 42px;
    background: #1e1712;
    transform: translateX(-50%) rotate(130deg);
  }

  .clock-center {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle at 35% 35%, #f0d18a, #a77721);
    box-shadow: 0 0 0 2px rgba(60, 35, 12, 0.2);
  }

  /* ventana del péndulo */
  .pendulum-window {
    width: 96px;
    height: 190px;
    margin: 0 auto;
    border-radius: 48px;
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(to bottom, rgba(30, 20, 12, 0.75), rgba(60, 40, 22, 0.5)),
      linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.12),
        rgba(255, 255, 255, 0.02)
      );
    box-shadow:
      inset 0 0 0 2px rgba(196, 153, 78, 0.22),
      inset 0 0 24px rgba(0, 0, 0, 0.3);
  }

  .pendulum-window::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      115deg,
      rgba(255, 255, 255, 0.18) 0%,
      rgba(255, 255, 255, 0.06) 22%,
      rgba(255, 255, 255, 0.01) 40%,
      transparent 55%
    );
    pointer-events: none;
  }

  /* péndulo */
  .pendulum {
    width: 6px;
    height: 128px;
    position: absolute;
    left: 50%;
    top: 14px;
    transform: translateX(-50%);
    transform-origin: top center;
    animation: swing 1.8s ease-in-out infinite alternate;
  }

  .pendulum__rod {
    width: 100%;
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(to right, #f0d493, #b78425, #f0d493);
    box-shadow: 0 0 4px rgba(255, 215, 130, 0.2);
  }

  .pendulum__bob {
    position: absolute;
    left: 50%;
    bottom: -26px;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    transform: translateX(-50%);
    background: radial-gradient(
      circle at 30% 30%,
      #f0d493 0%,
      #cf9b39 45%,
      #9f6d1c 100%
    );
    box-shadow:
      inset 0 2px 4px rgba(255, 255, 255, 0.3),
      inset 0 -5px 6px rgba(0, 0, 0, 0.18),
      0 4px 8px rgba(0, 0, 0, 0.18);
  }

  /* base */
  .pendulum-clock__base {
    width: 214px;
    height: 22px;
    margin-top: -4px;
    border-radius: 0 0 14px 14px;
    background: linear-gradient(to bottom, #6c4429, #442818);
    box-shadow:
      inset 0 2px 2px rgba(255, 255, 255, 0.08),
      inset 0 -3px 4px rgba(0, 0, 0, 0.18);
  }

  /* animación */
  @keyframes swing {
    from {
      transform: translateX(-50%) rotate(-12deg);
    }
    to {
      transform: translateX(-50%) rotate(12deg);
    }
  }
</style>
